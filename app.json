{
  "expo": {
    "name": "Zela Severiano",
    "slug": "zela-severiano",
    "version": "1.0.0",
    "scheme": "zelaseveriano",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {
        "usesCleartextTraffic": true
      },
      "package": "com.franciscopaulino.zelaseveriano"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "O Zela Severiano precisa acessar a câmera para registrar as fotos dos problemas urbanos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "O app precisa da sua localização para identificar onde está o problema na cidade."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "21a8a580-d2b5-4ba4-a279-10bfa9189c01"
      }
    }
  }
}
